# Zerodha Kite Connect credentials
# Get these from https://developers.kite.trade/
KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URL=http://localhost:3000/api/auth/callback

# Access token (generated daily via login flow)
# 1. Visit: https://kite.zerodha.com/connect/login?v=3&api_key=YOUR_API_KEY
# 2. Log in → redirected with request_token in URL
# 3. Exchange request_token for access_token:
#    curl -X POST https://api.kite.trade/session/token \
#      -d "api_key=YOUR_API_KEY" \
#      -d "request_token=YOUR_REQUEST_TOKEN" \
#      -d "checksum=$(echo -n 'API_KEY+REQUEST_TOKEN+API_SECRET' | shasum -a 256 | awk '{print $1}')"
KITE_ACCESS_TOKEN=

# Azure OpenAI (required for LLM-based strategies like llm_signal_generator)
# Get these from https://portal.azure.com → Azure OpenAI resource
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
